---
import Pagination from "@/components/Pagination.astro";
import ProductCard from "@/components/ProductCard.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllCategories, getProductsByCategory, paginateProducts } from "@/data/catalog";
import { PRODUCTS_PER_PAGE } from "@/config/site";

export function getStaticPaths() {
  return getAllCategories().map((category) => {
    const products = getProductsByCategory(category.slug);
    const pagination = paginateProducts(products, 1, PRODUCTS_PER_PAGE, (page) =>
      page <= 1 ? `/kategori/${category.slug}/` : `/kategori/${category.slug}/halaman/${page}/`,
    );

    return {
      params: { slug: category.slug },
      props: {
        category,
        products: pagination.items,
        meta: pagination.meta,
      },
    };
  });
}

const { category, products, meta } = Astro.props;
---

<BaseLayout
  title={category.label}
  description={`Katalog ${category.label} dari Gallery Furnicraft Jepara.`}
  canonicalPath={`/kategori/${category.slug}/`}
>
  <section class="container-shell pb-6 pt-12">
    <SectionHeading
      eyebrow="Kategori"
      title={category.label}
      description={`${meta.totalItems} produk tersedia pada kategori ini. Pilih model yang cocok lalu lanjutkan konsultasi bila dibutuhkan.`}
    />
  </section>

  <section class="container-shell pb-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((product, index) => (
        <ProductCard product={product} eager={index < 3} />
      ))}
    </div>
    <Pagination
      meta={meta}
      makePageUrl={(page) => (page <= 1 ? `/kategori/${category.slug}/` : `/kategori/${category.slug}/halaman/${page}/`)}
    />
  </section>
</BaseLayout>
