---
import { getOrderStatusLabel } from "@/server/orders";
import type { OrderStatus } from "@/types/order";

interface Props {
  status: OrderStatus;
}

const { status } = Astro.props;

const toneClass =
  status === "paid" || status === "completed"
    ? "bg-emerald-100 text-emerald-800"
    : status === "awaiting_verification" || status === "dp_received"
      ? "bg-amber-100 text-amber-800"
      : status === "cancelled"
        ? "bg-rose-100 text-rose-800"
        : "bg-slate-100 text-slate-800";
---

<span class:list={["inline-flex rounded-full px-3 py-1 text-xs font-semibold", toneClass]}>
  {getOrderStatusLabel(status)}
</span>
