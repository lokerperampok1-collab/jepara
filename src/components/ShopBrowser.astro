---
import ProductCard from "@/components/ProductCard.astro";
import type { CategorySummary, NormalizedProduct, PaginationMeta } from "@/types/catalog";

interface Props {
  initialProducts: NormalizedProduct[];
  initialMeta: PaginationMeta;
  categories: CategorySummary[];
  basePath?: string;
}

const {
  initialProducts,
  initialMeta,
  categories,
  basePath = "/shop/",
} = Astro.props;

const createPageUrl = (page: number) => (page <= 1 ? basePath : `${basePath}halaman/${page}/`);

function buildPageWindow(totalPages: number, currentPage: number) {
  if (totalPages <= 7) {
    return Array.from({ length: totalPages }, (_, index) => index + 1);
  }

  const pages = new Set<number>([1, totalPages, currentPage - 1, currentPage, currentPage + 1]);
  return [...pages]
    .filter((page) => page >= 1 && page <= totalPages)
    .sort((left, right) => left - right);
}

const visiblePages = buildPageWindow(initialMeta.totalPages, initialMeta.currentPage);
---

<section
  id="shop-browser"
  class="space-y-6"
  data-page-size={initialMeta.pageSize}
  data-base-path={basePath}
  data-initial-page={initialMeta.currentPage}
>
  <div class="surface-card rounded-[2rem] p-5 sm:p-6">
    <form id="catalog-filters" class="grid gap-4 md:grid-cols-[1.4fr_1fr_1fr_auto] md:items-end">
      <label class="space-y-2">
        <span class="text-sm font-medium text-[color:var(--color-body)]">Cari produk</span>
        <input
          name="q"
          type="search"
          placeholder="Cari model, nama produk, atau kategori..."
          class="w-full rounded-2xl border border-[color:var(--color-border)] bg-white px-4 py-3 text-sm outline-none transition focus:border-[color:var(--color-wood)]"
        />
      </label>

      <label class="space-y-2">
        <span class="text-sm font-medium text-[color:var(--color-body)]">Filter kategori</span>
        <select
          name="category"
          class="w-full rounded-2xl border border-[color:var(--color-border)] bg-white px-4 py-3 text-sm outline-none transition focus:border-[color:var(--color-wood)]"
        >
          <option value="">Semua kategori</option>
          {categories.map((category) => (
            <option value={category.slug}>{category.label}</option>
          ))}
        </select>
      </label>

      <label class="space-y-2">
        <span class="text-sm font-medium text-[color:var(--color-body)]">Urutkan</span>
        <select
          name="sort"
          class="w-full rounded-2xl border border-[color:var(--color-border)] bg-white px-4 py-3 text-sm outline-none transition focus:border-[color:var(--color-wood)]"
        >
          <option value="newest">Terbaru</option>
          <option value="oldest">Terlama</option>
          <option value="price-low">Harga terendah</option>
          <option value="price-high">Harga tertinggi</option>
        </select>
      </label>

      <button
        type="submit"
        class="inline-flex h-[3.25rem] items-center justify-center rounded-full bg-[color:var(--color-wood-deep)] px-6 text-sm font-semibold text-white transition hover:bg-[color:var(--color-wood)]"
      >
        Terapkan
      </button>
    </form>
  </div>

  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p id="catalog-summary" class="text-sm text-[color:var(--color-muted)]">
      Menampilkan {initialProducts.length} produk dari {initialMeta.totalItems} produk.
    </p>
    <p class="text-xs uppercase tracking-[0.22em] text-[color:var(--color-muted)]">
      Pilih kategori atau urutkan sesuai kebutuhan ruang Anda.
    </p>
  </div>

  <div id="catalog-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {initialProducts.map((product, index) => (
      <ProductCard product={product} eager={index < 3} />
    ))}
  </div>

  <nav id="catalog-js-pagination" class="flex flex-wrap items-center justify-center gap-3" hidden></nav>

  <div id="catalog-static-pagination" class="mt-2 flex flex-wrap items-center justify-center gap-3">
    {initialMeta.hasPrev && (
      <a
        href={createPageUrl(initialMeta.currentPage - 1)}
        class="rounded-full border border-[color:var(--color-border)] bg-white/70 px-4 py-2 text-sm font-medium text-[color:var(--color-body)] transition hover:border-[color:var(--color-wood)]"
      >
        Sebelumnya
      </a>
    )}
    {visiblePages.map((page, index) => (
      <>
        {index > 0 && page - visiblePages[index - 1] > 1 && (
          <span class="px-1 text-sm text-[color:var(--color-muted)]" aria-hidden="true">...</span>
        )}
        <a
          href={createPageUrl(page)}
          class:list={[
            "inline-flex h-11 min-w-11 items-center justify-center rounded-full border px-4 text-sm font-semibold transition",
            page === initialMeta.currentPage
              ? "border-[color:var(--color-wood-deep)] bg-[color:var(--color-wood-deep)] text-white"
              : "border-[color:var(--color-border)] bg-white/70 text-[color:var(--color-body)] hover:border-[color:var(--color-wood)]",
          ]}
        >
          {page}
        </a>
      </>
    ))}
    {initialMeta.hasNext && (
      <a
        href={createPageUrl(initialMeta.currentPage + 1)}
        class="rounded-full border border-[color:var(--color-border)] bg-white/70 px-4 py-2 text-sm font-medium text-[color:var(--color-body)] transition hover:border-[color:var(--color-wood)]"
      >
        Berikutnya
      </a>
    )}
  </div>
</section>

<script type="application/json" id="shop-browser-categories" set:html={JSON.stringify(categories)} />

<script is:inline>
  const shopBrowser = document.getElementById("shop-browser");

  if (shopBrowser && !shopBrowser.dataset.bound) {
    shopBrowser.dataset.bound = "true";

    const form = document.getElementById("catalog-filters");
    const grid = document.getElementById("catalog-grid");
    const summary = document.getElementById("catalog-summary");
    const pagination = document.getElementById("catalog-js-pagination");
    const staticPagination = document.getElementById("catalog-static-pagination");
    const categories = JSON.parse(document.getElementById("shop-browser-categories")?.textContent ?? "[]");
    const pageSize = Number(shopBrowser.dataset.pageSize ?? "18");
    const basePath = shopBrowser.dataset.basePath ?? "/shop/";
    let catalogIndexPromise;

    const renderCard = (item) => {
      const status = item.statusLabel
        ? `<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] ${
            item.statusLabel === "Ready"
              ? "bg-[rgba(93,106,77,0.16)] text-[color:var(--color-moss)]"
              : "bg-[rgba(127,79,42,0.14)] text-[color:var(--color-wood-deep)]"
          }">${item.statusLabel}</span>`
        : "";
      const category = item.categoryLabels?.[0]
        ? `<span class="rounded-full bg-[rgba(38,26,18,0.06)] px-3 py-1 text-xs font-medium text-[color:var(--color-body)]">${item.categoryLabels[0]}</span>`
        : "";

      return `
        <article class="surface-card group overflow-hidden rounded-[1.75rem]">
          <a href="${item.url}" class="block">
            <div class="aspect-[4/4.7] overflow-hidden bg-[rgba(127,79,42,0.08)]">
              ${
                item.image
                  ? `<img src="${item.image}" alt="${item.title}" class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04]" loading="lazy" decoding="async" />`
                  : `<div class="flex h-full items-center justify-center px-8 text-center text-sm text-[color:var(--color-muted)]">Foto produk belum tersedia</div>`
              }
            </div>
          </a>
          <div class="space-y-4 p-5">
            <div class="flex flex-wrap items-center gap-2">${status}${category}</div>
            <div>
              <h3 class="serif-display text-xl font-semibold leading-snug text-[color:var(--color-ink)]">
                <a href="${item.url}" class="transition hover:text-[color:var(--color-wood)]">${item.title}</a>
              </h3>
              <p class="line-clamp-3 mt-3 text-sm leading-6 text-[color:var(--color-muted)]">${item.excerpt ?? ""}</p>
            </div>
            <div class="flex items-end justify-between gap-4">
              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-muted)]">Harga</p>
                <p class="mt-1 text-lg font-semibold text-[color:var(--color-wood-deep)]">${item.priceFormatted ?? "Hubungi kami"}</p>
              </div>
              <a href="${item.url}" class="inline-flex items-center justify-center rounded-full border border-[color:var(--color-border)] bg-white/80 px-4 py-2 text-sm font-semibold text-[color:var(--color-ink)] transition hover:border-[color:var(--color-wood-deep)] hover:text-[color:var(--color-wood-deep)]">
                Lihat produk
              </a>
            </div>
          </div>
        </article>
      `;
    };

    const normalizeSort = (items, sort) => {
      const next = [...items];
      next.sort((a, b) => {
        if (sort === "oldest") {
          return a.dateValue - b.dateValue;
        }
        if (sort === "price-low") {
          return (a.priceValue ?? Number.MAX_SAFE_INTEGER) - (b.priceValue ?? Number.MAX_SAFE_INTEGER);
        }
        if (sort === "price-high") {
          return (b.priceValue ?? -1) - (a.priceValue ?? -1);
        }
        return b.dateValue - a.dateValue;
      });
      return next;
    };

    const getCatalogIndex = async () => {
      if (!catalogIndexPromise) {
        catalogIndexPromise = fetch("/catalog-index.json").then((response) => response.json());
      }
      return catalogIndexPromise;
    };

    const applyStateToForm = (params) => {
      if (!(form instanceof HTMLFormElement)) {
        return;
      }
      const q = form.elements.namedItem("q");
      const category = form.elements.namedItem("category");
      const sort = form.elements.namedItem("sort");
      if (q instanceof HTMLInputElement) q.value = params.get("q") ?? "";
      if (category instanceof HTMLSelectElement) category.value = params.get("category") ?? "";
      if (sort instanceof HTMLSelectElement) sort.value = params.get("sort") ?? "newest";
    };

    const renderPagination = (page, totalPages, params) => {
      if (!(pagination instanceof HTMLElement)) {
        return;
      }

      if (totalPages <= 1) {
        pagination.hidden = true;
        pagination.innerHTML = "";
        return;
      }

      pagination.hidden = false;
      const parts = [];

      const buildPageWindow = (total, current) => {
        if (total <= 7) {
          return Array.from({ length: total }, (_, index) => index + 1);
        }

        const pages = new Set([1, total, current - 1, current, current + 1]);
        return [...pages].filter((value) => value >= 1 && value <= total).sort((a, b) => a - b);
      };

      const createButton = (targetPage, label, isActive = false) => {
        const nextParams = new URLSearchParams(params);
        if (targetPage <= 1) {
          nextParams.delete("page");
        } else {
          nextParams.set("page", String(targetPage));
        }

        const href = `${basePath}?${nextParams.toString()}`;
        const className = isActive
          ? "inline-flex h-11 min-w-11 items-center justify-center rounded-full border border-[color:var(--color-wood-deep)] bg-[color:var(--color-wood-deep)] px-4 text-sm font-semibold text-white"
          : "inline-flex h-11 min-w-11 items-center justify-center rounded-full border border-[color:var(--color-border)] bg-white/70 px-4 text-sm font-semibold text-[color:var(--color-body)]";
        return `<a href="${href}" data-js-page="${targetPage}" class="${className}">${label}</a>`;
      };

      if (page > 1) {
        parts.push(createButton(page - 1, "Sebelumnya"));
      }

      const visiblePages = buildPageWindow(totalPages, page);
      visiblePages.forEach((current, index) => {
        if (index > 0 && current - visiblePages[index - 1] > 1) {
          parts.push(`<span class="px-1 text-sm text-[color:var(--color-muted)]" aria-hidden="true">...</span>`);
        }
        parts.push(createButton(current, String(current), current === page));
      });

      if (page < totalPages) {
        parts.push(createButton(page + 1, "Berikutnya"));
      }

      pagination.innerHTML = parts.join("");
    };

    const renderResults = async (options = { pushHistory: false }) => {
      const params = new URLSearchParams(window.location.search);
      const q = (params.get("q") ?? "").trim().toLowerCase();
      const category = params.get("category") ?? "";
      const sort = params.get("sort") ?? "newest";
      const requestedPage = Math.max(Number(params.get("page") ?? "1"), 1);
      const hasActiveFilters = Boolean(q || category || sort !== "newest" || requestedPage > 1);

      applyStateToForm(params);

      if (!hasActiveFilters) {
        if (pagination instanceof HTMLElement) {
          pagination.hidden = true;
          pagination.innerHTML = "";
        }
        if (staticPagination instanceof HTMLElement) {
          staticPagination.hidden = false;
        }
        return;
      }

      const catalogIndex = await getCatalogIndex();
      let results = catalogIndex.items;

      if (category) {
        results = results.filter((item) => item.categories.includes(category));
      }

      if (q) {
        results = results.filter((item) => item.searchText.includes(q));
      }

      results = normalizeSort(results, sort);

      const totalItems = results.length;
      const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
      const safePage = Math.min(requestedPage, totalPages);
      const start = (safePage - 1) * pageSize;
      const pageItems = results.slice(start, start + pageSize);

      if (grid instanceof HTMLElement) {
        grid.innerHTML = pageItems.length
          ? pageItems.map((item) => renderCard(item)).join("")
          : `<div class="surface-card rounded-[1.75rem] px-6 py-10 text-center text-sm text-[color:var(--color-muted)] sm:col-span-2 lg:col-span-3">Produk tidak ditemukan. Coba ubah kata kunci, kategori, atau urutan.</div>`;
      }

      if (summary instanceof HTMLElement) {
        const activeCategory = categories.find((item) => item.slug === category)?.label;
        summary.textContent = activeCategory
          ? `Menampilkan ${pageItems.length} produk dari ${totalItems} pilihan untuk kategori ${activeCategory}.`
          : `Menampilkan ${pageItems.length} produk dari ${totalItems} hasil pencarian.`;
      }

      if (staticPagination instanceof HTMLElement) {
        staticPagination.hidden = true;
      }

      renderPagination(safePage, totalPages, params);

      if (options.pushHistory && safePage !== requestedPage) {
        params.set("page", String(safePage));
        history.replaceState({}, "", `${basePath}?${params.toString()}`);
      }
    };

    applyStateToForm(new URLSearchParams(window.location.search));
    renderResults();

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      const formData = new FormData(form);
      const params = new URLSearchParams();
      const q = String(formData.get("q") ?? "").trim();
      const category = String(formData.get("category") ?? "").trim();
      const sort = String(formData.get("sort") ?? "newest").trim();

      if (q) params.set("q", q);
      if (category) params.set("category", category);
      if (sort && sort !== "newest") params.set("sort", sort);

      history.pushState({}, "", params.toString() ? `${basePath}?${params.toString()}` : basePath);
      await renderResults();
    });

    pagination?.addEventListener("click", async (event) => {
      const link = event.target instanceof Element ? event.target.closest("[data-js-page]") : null;
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      event.preventDefault();
      history.pushState({}, "", link.href);
      await renderResults();
    });

    window.addEventListener("popstate", () => {
      renderResults();
    });
  }
</script>
