---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  description,
  align = "left",
} = Astro.props;
---

<div class:list={["max-w-3xl", align === "center" ? "mx-auto text-center" : ""]}>
  {eyebrow && (
    <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-[color:var(--color-wood)]">
      {eyebrow}
    </p>
  )}
  <h2 class="serif-display mt-3 text-3xl font-semibold leading-tight text-[color:var(--color-ink)] sm:text-4xl">
    {title}
  </h2>
  {description && <p class="mt-4 text-base leading-7 text-[color:var(--color-muted)]">{description}</p>}
</div>
