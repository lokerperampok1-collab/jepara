---
interface Props {
  href: string | null;
  label?: string;
}

const { href, label = "Tanya via Telegram" } = Astro.props;
---

{
  href && (
    <a
      href={href}
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center justify-center rounded-full bg-[color:var(--color-wood-deep)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[color:var(--color-wood)]"
    >
      {label}
    </a>
  )
}
